# Poolula Platform - Environment Variables Template
# Copy this file to .env and fill in your values

# =============================================================================
# Database Configuration
# =============================================================================

# SQLite (development - default)
DATABASE_URL=sqlite:///./poolula.db

# PostgreSQL (production - when scaling)
# DATABASE_URL=postgresql://user:password@localhost:5432/poolula_db

# =============================================================================
# API Settings (Phase 1)
# =============================================================================

API_HOST=0.0.0.0
API_PORT=8082
API_RELOAD=true

# =============================================================================
# Application Settings
# =============================================================================

ENV=development
DEBUG=false
LOG_LEVEL=INFO

# =============================================================================
# AI & RAG Configuration (Phase 2+)
# =============================================================================

# Anthropic API key (required for chatbot in Phase 2)
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Vector Store (Phase 2)
# CHROMA_PERSIST_DIRECTORY=./chroma_db
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# =============================================================================
# Security (Future)
# =============================================================================

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# SECRET_KEY=generate_a_secure_random_key_here

# =============================================================================
# Feature Flags
# =============================================================================

# Phase 2+
ENABLE_RAG_CHATBOT=false
ENABLE_NEO4J=false

# Phase 5+
ENABLE_ADVANCED_ANALYTICS=false
